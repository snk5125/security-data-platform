# Copy this file to backend.tf and fill in the key for this workload.
terraform {
  backend "s3" {
    bucket         = "security-lakehouse-tfstate-337394138208"
    key            = "workloads/azure-workload-CHANGEME/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "security-lakehouse-tflock"
    encrypt        = true
  }
}
