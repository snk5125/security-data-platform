# -----------------------------------------------------------------------------
# PoC Environment — Variable Values (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in your real values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Sensitive values (databricks_pat) should be set via environment variable:
#   export TF_VAR_databricks_pat="dapi..."
# -----------------------------------------------------------------------------

# ── AWS Account Topology ──────────────────────────────────────────────────────
aws_region            = "us-east-1"
security_account_id   = "<SECURITY_ACCOUNT_ID>"       # 12-digit AWS account ID
workload_a_account_id = "<WORKLOAD_A_ACCOUNT_ID>"     # 12-digit AWS account ID
workload_b_account_id = "<WORKLOAD_B_ACCOUNT_ID>"     # 12-digit AWS account ID
organization_id       = "<ORGANIZATION_ID>"            # e.g., o-xxxxxxxxxx

# ── Databricks (Phase 5+) ────────────────────────────────────────────────────
databricks_workspace_url = "https://<WORKSPACE>.cloud.databricks.com"

# ── External IDs (two-pass pattern) ──────────────────────────────────────────
# After Phase 5 first apply, Databricks assigns external IDs to storage
# credentials. Retrieve them from the Databricks UI or API, then update here
# and re-apply. Use "0000" as placeholder for the initial apply.
databricks_storage_credential_external_id = "0000"
databricks_hub_credential_external_id     = "0000"

# ── Self-assume (Phase 5.5) ─────────────────────────────────────────────────
# Set to true AFTER Phase 5 creates storage credentials. Adds self-assume to
# IAM trust policies (required by Databricks since Jan 2025).
enable_self_assume = false
