# -----------------------------------------------------------------------------
# Remote State Backend (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to backend.tf and fill in your real values:
#   cp backend.tf.example backend.tf
#
# Points to the S3 bucket and DynamoDB table created by the bootstrap module.
# The bucket provides versioned, encrypted state storage; the DynamoDB table
# provides distributed locking to prevent concurrent applies.
#
# Prerequisites: bootstrap/ must be applied first (Phase 1, Steps 1-2).
# -----------------------------------------------------------------------------
terraform {
  backend "s3" {
    bucket         = "security-lakehouse-tfstate-<ACCOUNT_ID>"
    key            = "environments/poc/terraform.tfstate"
    region         = "<REGION>"
    dynamodb_table = "security-lakehouse-tflock"
    encrypt        = true
  }
}
