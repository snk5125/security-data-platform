{
  "id": "in_auth_logs",
  "type": "file",
  "disabled": false,
  "sendToRoutes": false,
  "mode": "manual",
  "path": "/var/log/",
  "filenames": ["*/auth.log", "*/secure"],
  "tailOnly": false,
  "interval": 10,
  "connections": [{"output": "stream-tcp", "pipeline": "auth_enrichment"}],
  "description": "Monitor auth logs (auth.log on Debian/Ubuntu, secure on RHEL/Amazon Linux)"
}
