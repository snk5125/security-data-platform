{
  "id": "auditd_enrichment",
  "conf": {
    "asyncFuncTimeout": 1000,
    "output": "default",
    "groups": {},
    "description": "Enriches auditd events with source_type and audit_type fields",
    "functions": [
      {
        "id": "eval",
        "filter": "true",
        "disabled": false,
        "conf": {
          "add": [
            {"name": "cribl", "value": "'yes'"},
            {"name": "source_type", "value": "'auditd'"},
            {"name": "audit_type", "value": "/type=(EXECVE|SYSCALL)/.test(_raw) ? 'process' : /type=(USER_AUTH|USER_LOGIN|CRED_ACQ)/.test(_raw) ? 'auth' : /type=(ADD_USER|DEL_USER|USER_ACCT)/.test(_raw) ? 'account' : 'system'"}
          ]
        }
      }
    ]
  }
}
