# =============================================================================
# Terraform
# =============================================================================

# State files — contain resource metadata, ARNs, and account identifiers.
# State is stored remotely in S3; local copies must not be committed.
*.tfstate
*.tfstate.*

# Provider plugins and module cache — large, platform-specific, regenerated
# by `terraform init`.
.terraform/
.terraform.d/

# Variable values — contains real account IDs, workspace URLs, and external
# IDs. Use terraform.tfvars.example as a template.
*.tfvars
!*.tfvars.example

# Override files (used for local dev overrides, not committed)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files — binary output of `terraform plan`; may contain credentials,
# ARNs, and access keys embedded in resource diffs.
tfplan
*.tfplan

# Crash logs
crash.log
crash.*.log

# =============================================================================
# Credentials and local configuration
# =============================================================================

# Claude Code local settings — may contain tokens in command history
.claude/

# Superpowers skills (local Claude Code extensions)
superpowers/
.superpowers/
docs/superpowers/

# AI dev-kit metadata and MCP config (local tooling, not project code)
.ai-dev-kit/
.mcp.json

# Environment files
.env
.env.*

# Key material
*.pem
*.key

# =============================================================================
# OS and editor artifacts
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Backup and temp files (from sed operations in onboarding script)
# =============================================================================

*.bak
*.tmp

# =============================================================================
# Generated diagram artifacts (regenerable from .mmd sources)
# =============================================================================

diagrams/*.png
diagrams/*.svg

# =============================================================================
# Multi-root generated files
# =============================================================================

# Generated by assemble-workloads.sh — contains workload outputs
hub/workloads.auto.tfvars.json

# State migration backups
.state-migration-backup/

# Git worktrees (isolated development workspaces)
.worktrees/

# Backend configuration — all roots use backend.tf.example as template
**/backend.tf
!**/backend.tf.example

# Terraform lock files in modules (regenerated by terraform init)
.terraform.lock.hcl

# =============================================================================
# Ansible
# =============================================================================

# Ansible SSH keys extracted from Terraform state (sensitive, ephemeral)
ansible/inventory/.keys/
ansible/inventory/hosts.json
