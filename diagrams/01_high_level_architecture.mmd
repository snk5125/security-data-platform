graph TB
    classDef awsBox fill:#FF9900,color:#fff,stroke:#232F3E,stroke-width:2px
    classDef azureBox fill:#0078D4,color:#fff,stroke:#003A6C,stroke-width:2px
    classDef dbxBox fill:#FF3621,color:#fff,stroke:#8B0000,stroke-width:2px
    classDef s3Box fill:#3F8624,color:#fff,stroke:#2E6B1A,stroke-width:2px
    classDef iamBox fill:#DD344C,color:#fff,stroke:#8B0000,stroke-width:2px
    classDef ec2Box fill:#ED7100,color:#fff,stroke:#9B4B00,stroke-width:2px
    classDef kmsBox fill:#DD344C,color:#fff,stroke:#8B0000,stroke-width:2px
    classDef dataBox fill:#8C4FFF,color:#fff,stroke:#5A2D9E,stroke-width:2px
    classDef adlsBox fill:#0078D4,color:#fff,stroke:#003A6C,stroke-width:2px

    %% ═══════════════════════════════════════════════════════
    %% DATABRICKS LAYER
    %% ═══════════════════════════════════════════════════════
    subgraph DBX ["DATABRICKS FREE EDITION — <WORKSPACE>.cloud.databricks.com"]
        direction LR

        subgraph UC ["Unity Catalog"]
            direction TB
            CAT["security_poc catalog"]
            SCHEMAS["bronze | silver | gold | security"]
            CAT --- SCHEMAS
        end

        subgraph COMPUTE ["Compute"]
            DW["Serverless Starter Warehouse"]
        end

        subgraph JOBS ["Scheduled Jobs (11 Jobs, PAUSED)"]
            direction TB
            J1["CloudTrail<br/>1 task · 15 min"]
            J2["bronze-vpc-flow-ingest<br/>3 tasks · 10 min<br/>ingest → gold_alerts → forward_alerts"]
            J3["GuardDuty<br/>1 task · 6 hr"]
            J4["Config Pipeline<br/>3 tasks · 24 hr<br/>bronze → silver CDC → gold EC2"]
            J5["Threat Intel Pipeline<br/>2 tasks · daily 01:00 UTC<br/>bronze_ingest → silver_network"]
            J6["Activity Log<br/>1 task · 15 min"]
            J7["Azure VNet Flow<br/>3 tasks · 10 min<br/>ingest → gold_alerts → forward_alerts"]
            J8["GCP Audit Logs<br/>1 task · 15 min"]
            J9["GCP VPC Flow<br/>3 tasks · 10 min<br/>ingest → gold_alerts → forward_alerts"]
            J10["GCP Asset Inventory<br/>1 task · 24 hr"]
            J11["GCP SCC Findings<br/>1 task · 6 hr"]
        end

        subgraph NOTEBOOKS ["Notebooks (20)"]
            direction TB
            subgraph NB_BRONZE ["Bronze/AWS (5)"]
                direction LR
                NB0["00_ocsf_common"]
                NB1["01_cloudtrail"]
                NB2["02_vpc_flow"]
                NB3["03_guardduty"]
                NB4["04_config"]
            end
            subgraph NB_AZ_BRONZE ["Bronze/Azure (3)"]
                direction LR
                NBA0["00_azure_common"]
                NBA1["01_activity_log"]
                NBA2["02_vnet_flow"]
            end
            subgraph NB_GCP_BRONZE ["Bronze/GCP (5)"]
                direction LR
                NBG0["00_gcp_common"]
                NBG1["01_cloud_audit_logs"]
                NBG2["02_vpc_flow_logs"]
                NBG3["03_asset_inventory"]
                NBG4["04_scc_findings"]
            end
            subgraph NB_TI ["Threat Intel (3)"]
                direction LR
                NB_TI0["00_threat_intel_common"]
                NB_TI1["01_bronze_ingest"]
                NB_TI2["02_silver_network"]
            end
            subgraph NB_SILVER ["Silver (1)"]
                NB5["01_silver_config_cdc"]
            end
            subgraph NB_GOLD ["Gold (3)"]
                NB6["01_gold_ec2_inventory"]
                NB7["02_gold_alerts"]
                NB8["03_gold_alerts_forward"]
            end
        end

        subgraph CREDS ["Storage Credentials → External Locations"]
            direction LR
            HC["hub-credential → security-logs-workload-a, security-logs-workload-b"]
            MC["managed-credential → managed-storage"]
            AZC["azure-credential → activity-logs-azure-workload-a, flow-logs-azure-workload-a"]
            GCPCRED["gcp-credential → security-logs-gcp-workload-a"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% SECURITY ACCOUNT
    %% ═══════════════════════════════════════════════════════
    subgraph SEC ["AWS SECURITY ACCOUNT — <SECURITY_ACCOUNT_ID>"]
        direction LR

        subgraph IAM_SEC ["IAM Roles"]
            direction TB
            HUB["lakehouse-hub-role<br/>AssumeRole → workload read-only roles<br/>S3 read + KMS decrypt"]
            MSR["lakehouse-managed-storage-role<br/>S3 read/write to managed bucket"]
        end

        subgraph S3_SEC ["S3 Buckets"]
            direction TB
            MSB["security-lakehouse-managed-<SECURITY_ACCOUNT_ID><br/>Delta table storage (managed by Databricks)"]
            STB["security-lakehouse-tfstate-<SECURITY_ACCOUNT_ID><br/>Terraform remote state"]
        end

        DDB["DynamoDB: security-lakehouse-tflock"]

        subgraph SNS_SEC ["SNS Alerts"]
            direction TB
            SNS["security-lakehouse-alerts<br/>SNS topic"]
            SNSU["lakehouse-sns-publisher<br/>IAM user · sns:Publish only"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% AZURE FOUNDATION
    %% ═══════════════════════════════════════════════════════
    subgraph AZFOUND ["AZURE FOUNDATION — Entra ID + Managed Storage"]
        direction LR
        AZSP["Entra ID Service Principal<br/>lakehouse-databricks-sp"]
        AZMGD["ADLS Gen2: <AZURE_MANAGED_STORAGE_ACCOUNT><br/>Managed storage (future use)"]
    end

    %% ═══════════════════════════════════════════════════════
    %% WORKLOAD A (AWS)
    %% ═══════════════════════════════════════════════════════
    subgraph WKA ["AWS WORKLOAD ACCOUNT A — <WORKLOAD_A_ACCOUNT_ID>"]
        direction LR

        subgraph NET_A ["VPC 10.0.0.0/16 — Subnet 10.0.1.0/24"]
            direction LR
            EC2AL["Linux t2.micro<br/><PUBLIC_IP>"]
            EC2AW["Windows t2.micro<br/><PUBLIC_IP>"]
            SGA["SG: 0.0.0.0/0<br/>:22, :3389 inbound"]
        end

        subgraph DATA_A ["Data Sources"]
            direction LR
            CTA["CloudTrail"]
            FLA["VPC Flow Logs"]
            GDA["GuardDuty"]
            CFA["AWS Config"]
        end

        subgraph STORE_A ["Storage & IAM"]
            direction TB
            S3A["S3: lakehouse-workload-a-security-logs-<WORKLOAD_A_ACCOUNT_ID>"]
            KMSA["KMS: <KMS_KEY_PREFIX>... (GuardDuty)"]
            ROA["lakehouse-workload-a-read-only-role"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% WORKLOAD B (AWS)
    %% ═══════════════════════════════════════════════════════
    subgraph WKB ["AWS WORKLOAD ACCOUNT B — <WORKLOAD_B_ACCOUNT_ID>"]
        direction LR

        subgraph NET_B ["VPC 10.1.0.0/16 — Subnet 10.1.1.0/24"]
            direction LR
            EC2BL["Linux t2.micro<br/><PUBLIC_IP>"]
            EC2BW["Windows t2.micro<br/><PUBLIC_IP>"]
            SGB["SG: 0.0.0.0/0<br/>:22, :3389 inbound"]
        end

        subgraph DATA_B ["Data Sources"]
            direction LR
            CTB["CloudTrail"]
            FLB["VPC Flow Logs"]
            GDB["GuardDuty"]
            CFB["AWS Config"]
        end

        subgraph STORE_B ["Storage & IAM"]
            direction TB
            S3B["S3: lakehouse-workload-b-security-logs-<WORKLOAD_B_ACCOUNT_ID>"]
            KMSB["KMS: <KMS_KEY_PREFIX>... (GuardDuty)"]
            ROB["lakehouse-workload-b-read-only-role"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% AZURE WORKLOAD A
    %% ═══════════════════════════════════════════════════════
    subgraph WKAZA ["AZURE WORKLOAD A — 3bd01bbf-6efb-..."]
        direction LR

        subgraph NET_AZ ["VNet 10.10.0.0/16 — Subnet 10.10.1.0/24"]
            direction LR
            VMAZL["Linux Standard_D2als_v7<br/>Ubuntu 22.04"]
            VMAZW["Windows Standard_D2als_v7<br/>Server 2022"]
            NSGAZ["NSG: 0.0.0.0/0<br/>:22, :3389 inbound"]
        end

        subgraph DATA_AZ ["Data Sources"]
            direction LR
            AZAL["Activity Log"]
            AZVFL["VNet Flow Logs<br/>(azurerm v4)"]
        end

        subgraph STORE_AZ ["Storage"]
            direction TB
            ADLSAZ["ADLS Gen2: <AZURE_LOGS_STORAGE_ACCOUNT><br/>Containers: insights-activity-logs,<br/>insights-logs-flowlogflowevent"]
            SPRA["SP: Storage Blob Data Reader"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% GCP FOUNDATION
    %% ═══════════════════════════════════════════════════════
    subgraph GCPFOUND ["GCP FOUNDATION — Service Account"]
        direction LR
        GCPSA["GCP Service Account<br/>lakehouse-databricks-sa"]
        GCPMGD["GCS: lakehouse-managed<br/>Managed storage (future use)"]
    end

    %% ═══════════════════════════════════════════════════════
    %% GCP WORKLOAD A
    %% ═══════════════════════════════════════════════════════
    subgraph WKGCPA ["GCP WORKLOAD A"]
        direction LR

        subgraph NET_GCP ["VPC 10.20.0.0/16 — Subnet 10.20.1.0/24"]
            direction LR
            VMGCPL["Linux e2-micro<br/>Ubuntu 22.04"]
            VMGCPW["Windows e2-medium<br/>Server 2022"]
            FWGCP["Firewall: 0.0.0.0/0<br/>:22, :3389 inbound"]
        end

        subgraph DATA_GCP ["Data Sources"]
            direction LR
            GCPAUDIT["Cloud Audit Logs"]
            GCPFLOW["VPC Flow Logs"]
            GCPASSET["Cloud Asset Inventory"]
            GCPSCC["SCC Findings"]
        end

        subgraph STORE_GCP ["Storage"]
            direction TB
            GCSGCP["GCS: security-logs<br/>Prefixes: audit-logs/, vpc-flow-logs/, asset-inventory/"]
            GCPRO["SA: objectViewer"]
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Databricks → Security Account (IAM chain)
    %% ═══════════════════════════════════════════════════════
    HC -.->|"sts:AssumeRole<br/>(ExternalID: ede6...)"| HUB
    MC -.->|"sts:AssumeRole<br/>(ExternalID: ede6...)"| MSR
    MSR -.->|"S3 read/write"| MSB

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Databricks → Azure (Entra ID)
    %% ═══════════════════════════════════════════════════════
    AZC -.->|"Entra ID auth"| AZSP
    AZSP -.->|"Storage Blob<br/>Data Reader"| ADLSAZ
    AZSP -.->|"Storage Blob<br/>Data Contributor"| AZMGD

    %% Two external locations for Azure workload-a (one per system-managed container)
    %% activity-logs-azure-workload-a → insights-activity-logs container
    %% flow-logs-azure-workload-a → insights-logs-flowlogflowevent container

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Databricks → GCP (SA Key)
    %% ═══════════════════════════════════════════════════════
    GCPCRED -.->|"SA Key auth"| GCPSA
    GCPSA -.->|"objectViewer"| GCSGCP

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Security Account → Workload Accounts (chain-assume)
    %% ═══════════════════════════════════════════════════════
    HUB -.->|"sts:AssumeRole"| ROA
    HUB -.->|"sts:AssumeRole"| ROB
    ROA -.->|"S3 read"| S3A
    ROB -.->|"S3 read"| S3B
    HUB -.->|"kms:Decrypt"| KMSA
    HUB -.->|"kms:Decrypt"| KMSB

    %% ═══════════════════════════════════════════════════════
    %% EDGES: EC2/VMs → Data Sources (telemetry generation)
    %% ═══════════════════════════════════════════════════════
    EC2AL -.-> DATA_A
    EC2AW -.-> DATA_A
    EC2BL -.-> DATA_B
    EC2BW -.-> DATA_B
    VMAZL -.-> DATA_AZ
    VMAZW -.-> DATA_AZ
    VMGCPL -.-> DATA_GCP
    VMGCPW -.-> DATA_GCP

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Data Sources → Storage (log delivery)
    %% ═══════════════════════════════════════════════════════
    CTA -->|"JSON.gz"| S3A
    FLA -->|"text.gz"| S3A
    GDA -->|"JSONL.gz<br/>(KMS encrypted)"| S3A
    CFA -->|"JSON.gz"| S3A

    CTB -->|"JSON.gz"| S3B
    FLB -->|"text.gz"| S3B
    GDB -->|"JSONL.gz<br/>(KMS encrypted)"| S3B
    CFB -->|"JSON.gz"| S3B

    AZAL -->|"JSON"| ADLSAZ
    AZVFL -->|"JSON"| ADLSAZ

    GCPAUDIT -->|"JSON"| GCSGCP
    GCPFLOW -->|"JSON"| GCSGCP
    GCPASSET -->|"JSON"| GCSGCP
    GCPSCC -->|"JSON"| GCSGCP

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Jobs → Notebooks
    %% ═══════════════════════════════════════════════════════
    J1 -->|"15 min"| NB1
    J2 -->|"10 min"| NB2
    J2 -->|"10 min"| NB7
    J2 -->|"10 min"| NB8
    J3 -->|"6 hr"| NB3
    J4 -->|"daily"| NB4
    J4 -->|"daily"| NB5
    J4 -->|"daily"| NB6
    J5 -->|"daily"| NB_TI1
    J5 -->|"daily"| NB_TI2
    J6 -->|"15 min"| NBA1
    J7 -->|"10 min"| NBA2
    J7 -->|"10 min"| NB7
    J7 -->|"10 min"| NB8
    J8 -->|"15 min"| NBG1
    J9 -->|"10 min"| NBG2
    J9 -->|"10 min"| NB7
    J9 -->|"10 min"| NB8
    J10 -->|"daily"| NBG3
    J11 -->|"6 hr"| NBG4

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Alert forwarding → SNS
    %% ═══════════════════════════════════════════════════════
    NB8 -->|"sns:Publish<br/>per new alert"| SNS
    SNSU -.->|"credentials<br/>(dbutils.secrets)"| NB8

    %% ═══════════════════════════════════════════════════════
    %% EDGES: Jobs read from storage via external locations
    %% ═══════════════════════════════════════════════════════
    J1 & J2 & J3 & J4 -->|"Auto Loader<br/>cloudFiles"| CREDS
    J6 & J7 -->|"Auto Loader<br/>cloudFiles (ADLS)"| CREDS
    J8 & J9 & J10 & J11 -->|"Auto Loader<br/>cloudFiles (GCS)"| CREDS
